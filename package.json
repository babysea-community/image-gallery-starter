{
  "name": "image-gallery-starter",
  "version": "0.1.0",
  "description": "Image gallery for generative media artworks.",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://image-gallery-starter.babysea.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-community/image-gallery-starter.git"
  },
  "keywords": [
    "babysea",
    "open-source",
    "ai-infrastructure",
    "control-plane",
    "execution-layer",
    "inference-providers",
    "developer-tools",
    "creative-tools",
    "generative-ai",
    "generative-media",
    "cloudflare-images",
    "sentry"
  ],
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "next dev --port=3011",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "sentry:check": "node scripts/sentry-project-check.mjs",
    "format": "prettier --check \"**/*.{ts,tsx,css,md,json,jsonc,mjs}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,css,md,json,jsonc,mjs}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@sentry/nextjs": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "catalog:",
    "simple-icons": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "catalog:",
    "@eslint/js": "catalog:",
    "@next/eslint-plugin-next": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@11.7.0"
}
